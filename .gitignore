parsed_output/
parsed_output_*/

# ── Uploaded files ────────────────────────────────────────────────────────────
uploads/

# ── Scripts (local data pipeline — not part of the app) ──────────────────────
scripts/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Vite / tooling cache ──────────────────────────────────────────────────────
.vite/
.cache/

# ── Claude Code project settings (machine-local) ──────────────────────────────
.claude/

